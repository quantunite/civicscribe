# CivicScribe production env (Railway, real backends).
#
# Copy these into the Railway service Variables. This is the LIVE configuration:
# MOCK_MODE is false, so every public generation spends real money on
# AssemblyAI + Anthropic. The cost/abuse guardrails below are load-bearing, not
# optional. Do NOT put real secret values in this file; it is an example only.

# --- Mode -------------------------------------------------------------------
# false = real Supabase + AssemblyAI + Anthropic. (true is the free mock demo.)
MOCK_MODE=false

# --- Supabase (Postgres + audio storage) ------------------------------------
# From Project Settings > API in the civicscribe Supabase project. The server
# reads/writes with the SERVICE_ROLE key (bypasses RLS); the ANON key is the
# public client key. Keep SERVICE_ROLE secret.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AssemblyAI: transcription + speaker diarization ------------------------
ASSEMBLYAI_API_KEY=your-assemblyai-key

# --- Anthropic: meeting summaries -------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-key
# Optional model override. Default: claude-sonnet-4-6.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- App URL ----------------------------------------------------------------
# The public origin of this deploy. Used for completion-email links, the OG /
# canonical metadataBase, and (when https) widening the CSP img/media-src so
# served audio loads. Set it to the Railway public domain.
APP_BASE_URL=https://YOUR-APP.up.railway.app

# --- Admin boundary ---------------------------------------------------------
# The single admin secret. REQUIRED in production: when unset the access layer
# is a complete no-op and everyone is treated as admin (fine for dev, unsafe
# public). Set a long random string. The UI carries it as the HttpOnly cs-owner
# cookie (sign in at /owner-login); scripts send "Authorization: Bearer <secret>".
# It gates delete/manage, speaker edits, schedules, publish/unpublish, and the
# /review moderation queue. Generate + read stay public (with the guardrails
# below). Keep it out of all logs; rotate by changing this value.
OWNER_SECRET=set-a-long-random-string

# --- Tick secret ------------------------------------------------------------
# Shared secret required to POST /api/jobs/tick. The in-process tick loop in
# scripts/railway-start.mjs reads the same value and sends it as a Bearer token,
# so set it here and the loop authenticates itself. Any external cron hitting
# /api/jobs/tick must send the same header.
TICK_SECRET=set-a-long-random-string

# --- Cost / abuse guardrails (public generation spends real money) ----------
# Admin (OWNER_SECRET) is exempt from all three. Each is a positive integer;
# a non-numeric or non-positive value falls back to the default.
# Max public submissions (generate + upload) per client IP per UTC day.
MAX_SUBMITS_PER_IP_PER_DAY=20
# Coarse global daily intake cap across ALL IPs per UTC day.
MAX_SUBMITS_GLOBAL_PER_DAY=200
# Upload size cap in megabytes (single source of truth for the upload route).
MAX_UPLOAD_MB=200

# --- Optional ---------------------------------------------------------------
# Zoom bot capture (Recall.ai). Leave unset if not capturing Zoom.
# RECALL_API_KEY=your-recall-key
# RECALL_REGION=us-west-2
# Shared secret for the Recall webhook; register as .../api/webhooks/recall?token=<secret>.
# RECALL_WEBHOOK_SECRET=set-a-long-random-string
# Completion email (Resend). Leave unset to log emails instead of sending.
# RESEND_API_KEY=your-resend-key
# NOTIFY_EMAIL=you@example.com

# --- Notes ------------------------------------------------------------------
# numReplicas MUST stay 1 (railway.json): two in-process tick loops would
# double-claim and double-spend on every job.
