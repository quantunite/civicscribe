# CivicScribe configuration.
# The app boots and runs end-to-end with ONLY this set:
MOCK_MODE=true

# --- Supabase (Postgres + storage). Leave unset in mock mode; the app falls
# back to a local file-backed store under DATA_DIR.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AssemblyAI: transcription + speaker diarization (one call).
ASSEMBLYAI_API_KEY=

# --- Anthropic: meeting summaries.
ANTHROPIC_API_KEY=
# Optional override. Default: claude-sonnet-4-6 (the spec's claude-sonnet-4-20250514
# is deprecated and retires 2026-06-15; claude-sonnet-4-6 is its replacement).
ANTHROPIC_MODEL=

# --- Recall.ai: Zoom bot capture. Signup approval required.
RECALL_API_KEY=
RECALL_REGION=us-west-2

# --- Resend: completion email. Stubbed — emails are logged to console in dev.
RESEND_API_KEY=
NOTIFY_EMAIL=

# --- Auth (single-user password gate).
# Leave APP_PASSWORD unset for local dev / mock mode (auth is then disabled).
# Set it to require a password before anyone can view or submit meetings —
# strongly recommended for any public/hosted deployment.
APP_PASSWORD=
# Secret used to sign session cookies. Optional: defaults to APP_PASSWORD.
# Set a long random value in production (e.g. `openssl rand -hex 32`).
AUTH_SECRET=

# --- Job tick auth.
# Shared secret required to call POST/GET /api/jobs/tick. When set, the worker
# (and any cron) must send it. Leave unset for local dev. Vercel Cron sends it
# automatically as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=

# --- Misc
# Base URL the worker uses to reach the app (default http://localhost:3000).
# In production set this to the deployed web URL (e.g. https://your-app.com).
APP_BASE_URL=
# Where mock-mode state + local audio files live (default .data).
DATA_DIR=
