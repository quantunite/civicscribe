# CivicScribe configuration.
# The app boots and runs end-to-end with ONLY this set:
MOCK_MODE=true

# --- Supabase (Postgres + storage). Leave unset in mock mode; the app falls
# back to a local file-backed store under DATA_DIR.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AssemblyAI: transcription + speaker diarization (one call).
ASSEMBLYAI_API_KEY=

# --- Anthropic: meeting summaries.
ANTHROPIC_API_KEY=
# Optional override. Default: claude-sonnet-4-6 (the spec's claude-sonnet-4-20250514
# is deprecated and retires 2026-06-15; claude-sonnet-4-6 is its replacement).
ANTHROPIC_MODEL=

# --- Recall.ai: Zoom bot capture. Signup approval required.
RECALL_API_KEY=
RECALL_REGION=us-west-2

# --- Resend: completion email. Stubbed — emails are logged to console in dev.
RESEND_API_KEY=
NOTIFY_EMAIL=

# --- Misc
# Base URL the worker uses to reach the app (default http://localhost:3000).
APP_BASE_URL=
# Where mock-mode state + local audio files live (default .data).
DATA_DIR=

# --- Public-deploy hardening (leave unset for local/single-user; the app stays
# fully open without them). Set BEFORE exposing the app publicly.
# Shared secret required to POST /api/jobs/tick. The worker (npm run worker)
# reads the same TICK_SECRET and sends it as "Authorization: Bearer <secret>";
# an external cron must send the same header.
TICK_SECRET=
# Shared secret for the Recall webhook. When set, register the webhook URL with
# Recall as .../api/webhooks/recall?token=<secret>. (Interim: switch to Svix
# signature verification once a real Recall webhook endpoint is registered.)
RECALL_WEBHOOK_SECRET=
